# Heirloom agent — environment variables
# Copy to .env for local dev. In TEE, MNEMONIC is auto-injected by KMS.

# === TEE wallet (auto-injected in EigenCompute, manual for local dev) ===
# Famous BIP-39 test phrase. KMS strips and re-injects in TEE.
MNEMONIC="test test test test test test test test test test test junk"

# === EigenAI inference path ===
# Primary: local Node sidecar (handles attestation + JWT minting via the
# official @layr-labs/ai-gateway-provider). Auto-runs in TEE.
SIDECAR_URL=http://127.0.0.1:9090

# Direct gateway HTTP — used as fallback if sidecar is unreachable. Inside the
# TEE these are auto-injected by KMS; locally you'd set KMS_AUTH_JWT manually
# from #ext-private-preview.
EIGEN_GATEWAY_URL=https://ai-gateway-dev.eigencloud.xyz
EIGEN_MODEL=anthropic/claude-sonnet-4.6
KMS_AUTH_JWT=
KMS_SERVER_URL=
KMS_PUBLIC_KEY=

# === Demo controls ===
# When true, APScheduler does not auto-advance phases — Director must drive.
DEMO_MODE=true
# Secret for /director?key=...
DIRECTOR_KEY=demo-secret-2026
# Compresses heartbeat intervals from days to seconds for testing
DEMO_FAST_TIMERS=true

# === Notifications ===
# Resend.com API key (free tier — 100/day). Empty = log-only stub.
RESEND_API_KEY=
RESEND_FROM_EMAIL=heirloom@yourdomain.com
# VAPID keys for Web Push (optional). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:heirloom@yourdomain.com

# === Chain RPCs (override defaults if rate-limited) ===
RPC_URL_1=https://eth.llamarpc.com
RPC_URL_8453=https://mainnet.base.org
RPC_URL_137=https://polygon-rpc.com
RPC_URL_11155111=https://rpc.sepolia.org
RPC_URL_84532=https://sepolia.base.org

# === Storage ===
DATABASE_PATH=./data/heirloom.db
AUDIT_PATH=./data/audit
USER_PERSISTENT_DATA_PATH=./data

# === Server ===
HOST=0.0.0.0
PORT=8080
PUBLIC_URL=
